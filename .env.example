# ============================================
# video2text 配置文件示例
# ============================================
# 复制此文件为 .env 并根据需要修改

# --------------------------------------------
# 服务端口配置
# --------------------------------------------
APP_PORT=7881

# Chrome 远程调试端口（用于 yt-dlp 下载某些平台视频）
BROWSER_DEBUG_PORT=9222

# --------------------------------------------
# 语音识别后端配置
# --------------------------------------------
# 默认识别后端
# 可选值：
#   - FunASR（Paraformer）  : 中文精度高，速度快（推荐中文）
#   - faster-whisper        : 多语言支持，OpenAI 出品
DEFAULT_BACKEND=FunASR（Paraformer）

# FunASR 模型（当 DEFAULT_BACKEND=FunASR（Paraformer）时使用）
# 可选值：
#   - paraformer-zh                    : 普通话精度推荐（默认）
#   - paraformer-zh-streaming          : 流式识别（低延迟）
#   - paraformer-en                    : 英文识别
#   - paraformer-zh-spk                : 中文+说话人分离
#   - iic/SenseVoiceSmall              : SenseVoice 小模型（支持情感识别）
#   - EfficientParaformer-large-zh     : 高效中文大模型
#   - EfficientParaformer-zh-en        : 中英双语
#   - iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch : 完整版大模型
DEFAULT_FUNASR_MODEL=paraformer-zh ⭐ 普通话精度推荐

# Whisper 模型（当 DEFAULT_BACKEND=faster-whisper 时使用）
# 可选值：
#   - tiny      : 最小最快，精度较低 (~39MB)
#   - base      : 基础模型 (~74MB)
#   - small     : 小模型 (~244MB)
#   - medium    : 中等模型，推荐（默认）(~769MB)
#   - large-v3  : 最大最准确 (~1.5GB)
DEFAULT_WHISPER_MODEL=medium

# --------------------------------------------
# 字幕下载配置
# --------------------------------------------
# 自动字幕优先语言（从平台下载已有字幕时优先选择）
# 可选值：
#   - zh    : 中文（默认）
#   - en    : 英文
#   - yue   : 粤语
#   - ja    : 日语
#   - ko    : 韩语
#   - es    : 西班牙语
#   - auto  : 自动检测
AUTO_SUBTITLE_LANG=zh

# --------------------------------------------
# 在线翻译模型配置
# --------------------------------------------
# 当前激活的配置组名称
ONLINE_MODEL_ACTIVE_PROFILE=default

# 配置组数量
ONLINE_MODEL_PROFILE_COUNT=1

# 配置组 1（可添加更多组，如 ONLINE_MODEL_PROFILE_2_xxx）
ONLINE_MODEL_PROFILE_1_NAME=default
ONLINE_MODEL_PROFILE_1_BASE_URL=https://api.siliconflow.cn/v1
ONLINE_MODEL_PROFILE_1_API_KEY=
ONLINE_MODEL_PROFILE_1_DEFAULT_MODEL=tencent/Hunyuan-MT-7B
ONLINE_MODEL_PROFILE_1_MODEL_LIST_JSON=["tencent/Hunyuan-MT-7B"]

# --------------------------------------------
# 性能调优配置
# --------------------------------------------
# FFmpeg 线程数（音频提取/切分）
# 建议值：CPU 核心数，或 4
FFMPEG_THREADS=4

# FunASR 每批处理秒数
# 较大的值可提高吞吐量，但需要更多显存
# 建议值：300（5分钟）
FUNASR_BATCH_SIZE_S=300

# Intel GPU 优先（仅 FunASR 后端支持）
# 可选值：
#   - 0 : 不优先使用 Intel GPU（默认）
#   - 1 : 优先使用 Intel GPU（需安装 Intel oneAPI）
# 注意：faster-whisper 不支持 Intel GPU
PREFER_INTEL_GPU=0

# --------------------------------------------
# 存储配置
# --------------------------------------------
# 临时视频保留数量（workspace/temp_video）
# 超过此数量的旧文件会被自动清理
TEMP_VIDEO_KEEP_COUNT=5
